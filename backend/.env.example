MYINSTA_DATABASE_PATH=./data/myinsta.sqlite3
MYINSTA_DOWNLOAD_DIR=./data/downloads
MYINSTA_AUDIO_DIR=./data/audio
MYINSTA_LIBRARY_DIR=./data/library
MYINSTA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MYINSTA_WHISPER_MODEL=base

# Brave Search API — free tier 2000 queries/month
# Get your key at: https://brave.com/search/api/
MYINSTA_BRAVE_SEARCH_API_KEY=your_key_here

# Instagram cookies for yt-dlp
INSTAGRAM_COOKIES_FILE=/home/nasser/.config/myinsta/instagram_cookies.txt
