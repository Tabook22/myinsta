MYINSTA_DATABASE_PATH=./data/myinsta.sqlite3
MYINSTA_DOWNLOAD_DIR=./data/downloads
MYINSTA_AUDIO_DIR=./data/audio
MYINSTA_LIBRARY_DIR=./data/library
MYINSTA_WIKI_DIR=./data/mywiki
MYINSTA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MYINSTA_WHISPER_MODEL=base
# 0 disables the YouTube duration guard. Set seconds here to re-enable it.
MYINSTA_MAX_YOUTUBE_DURATION_SECONDS=0

# Brave Search API — free tier 2000 queries/month
# Get your key at: https://brave.com/search/api/
MYINSTA_BRAVE_SEARCH_API_KEY=your_key_here

# Instagram cookies for yt-dlp (Netscape cookies.txt)
INSTAGRAM_COOKIES_FILE=/home/nasser/.config/myinsta/instagram_cookies.txt

# ── YouTube downloads (most failures are cookies / outdated yt-dlp) ──────────
# VPS (recommended): export cookies.txt from a browser signed into YouTube.
# Extension: "Get cookies.txt LOCALLY" → save as youtube_cookies.txt → copy to VPS.
YOUTUBE_COOKIES_FILE=/home/nasser/.config/myinsta/youtube_cookies.txt

# Local Windows/macOS only: read cookies from a browser profile instead of a file.
# Examples: chrome, edge, firefox  (leave empty on VPS)
YOUTUBE_COOKIES_FROM_BROWSER=

# Also required on the server for many videos:
# 1) Node.js on PATH  (for signature / EJS challenges)
# 2) Fresh yt-dlp:    pip install -U "yt-dlp[default]"
